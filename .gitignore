# =============================================================================
# Iris - local build artifacts, caches, runtime state, and secrets
# Cross-platform rules use forward slashes for Git compatibility.
# =============================================================================

# --- Dependencies ---
node_modules/

# --- Frontend build ---
dist/
.vite/
*.tsbuildinfo

# --- Rust / Tauri build output ---
target/
**/target/
**/target-codex*/
src-tauri/gen/
src-tauri/WixTools/
src-tauri/icons-staging/
src-tauri/icons-fresh/

# Exported/vault HTML can contain user document content; never commit it.
src-tauri/*.html
src-tauri/**/*.html

# Regenerate branding: npm run icon:gen (do not commit root copy).
/app-icon.png

# --- Iris local runtime state ---
.iris-dev/
.iris/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal

# --- Model and tool caches ---
.npm-cache/
.ort-cache/
.fastembed_cache/
**/.fastembed_cache/
.hf-cache/
.cache/
.eslintcache
.prettiercache

# --- Test and coverage artifacts ---
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# --- Logs and temp files ---
*.log
*.tmp
*.temp
*.part
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Secrets and credentials (never commit) ---
.env
.env.*
!.env.example
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# --- OS junk ---
.DS_Store
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editor state ---
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# --- Agent local state ---
.worktrees/
.cursor/
.agent/
.claude/
.codex/
.learnings/
.opencode/
.superpowers/

# Local agent planning state
.zcode/

# --- Build / eval caches ---
.cargo-target/
docs/eval/results/
!docs/eval/results/
!docs/eval/results/v1.2.5-hybrid.json
