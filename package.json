{
  "name": "iris",
  "private": true,
  "version": "1.2.9",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-iris-env.mjs -- vite",
    "dev:desktop": "node scripts/with-iris-env.mjs -- node scripts/tauri-cli.mjs dev",
    "dev:desktop:vec": "node scripts/with-iris-env.mjs -- node scripts/tauri-cli.mjs dev --features sqlite-vec",
    "dev:desktop:sign": "node scripts/with-iris-env.mjs -- node scripts/sign-dev-macos.mjs",
    "tauri:build:vec": "node scripts/with-iris-env.mjs -- node scripts/tauri-cli.mjs build --features sqlite-vec",
    "package:local:mac": "node scripts/package-local.mjs mac",
    "package:local:mac:check": "node scripts/package-local.mjs --check mac",
    "package:local:win": "node scripts/package-local.mjs win",
    "package:local:win:check": "node scripts/package-local.mjs --check win",
    "package:local:win:vec": "node scripts/package-local.mjs --sqlite-vec win",
    "build": "node scripts/with-iris-env.mjs -- tsc -b && node scripts/with-iris-env.mjs -- vite build",
    "preview": "node scripts/with-iris-env.mjs -- vite preview",
    "tauri": "node scripts/with-iris-env.mjs -- node scripts/tauri-cli.mjs",
    "lint": "node scripts/with-iris-env.mjs -- eslint src --max-warnings 0",
    "lint:fix": "node scripts/with-iris-env.mjs -- eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,html}\" \"docs/**/*.md\" \"scripts/**/*.{mjs,js,ts}\" \"*.config.{js,ts,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,html}\" \"docs/**/*.md\" \"scripts/**/*.{mjs,js,ts}\" \"*.config.{js,ts,mjs}\"",
    "typecheck": "node scripts/with-iris-env.mjs -- tsc -b --noEmit",
    "test": "node scripts/with-iris-env.mjs -- vitest run",
    "test:coverage": "node scripts/with-iris-env.mjs -- vitest run --coverage",
    "test:watch": "node scripts/with-iris-env.mjs -- vitest",
    "test:e2e": "node scripts/with-iris-env.mjs -- vitest run --config vitest.e2e.config.ts",
    "test:desktop:windows": "node scripts/run-windows-persistence-e2e.mjs",
    "audit:rust": "node scripts/with-iris-env.mjs -- node scripts/cargo-audit.mjs",
    "model:prepare": "node scripts/prepare-embedding-model.mjs",
    "rag:eval": "node scripts/with-iris-env.mjs -- cargo test --manifest-path src-tauri/Cargo.toml --test rag_broker_eval -- --nocapture",
    "icon:gen": "node scripts/gen-icon.mjs",
    "icon:tauri": "npm run icon:gen && tauri icon scripts/assets/app-icon.png -o src-tauri/icons-staging && node scripts/sync-tauri-icons.mjs",
    "hygiene:scan": "node scripts/hygiene-scan.mjs",
    "hygiene:clean": "node scripts/hygiene-clean.mjs",
    "hygiene:gitignore-check": "node scripts/hygiene-gitignore-check.mjs",
    "version:set": "node scripts/set-version.mjs",
    "version:check": "node scripts/set-version.mjs --check",
    "docs:check": "node scripts/docs-facts-check.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-virtual": "^3.13.26",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.2",
    "@tiptap/core": "^2.14.0",
    "@tiptap/extension-blockquote": "^2.14.0",
    "@tiptap/extension-code-block": "^2.14.0",
    "@tiptap/extension-code-block-lowlight": "^2.14.0",
    "@tiptap/extension-paragraph": "^2.14.0",
    "@tiptap/extension-placeholder": "^2.14.0",
    "@tiptap/extension-table": "^2.14.0",
    "@tiptap/extension-table-cell": "^2.14.0",
    "@tiptap/extension-table-header": "^2.14.0",
    "@tiptap/extension-table-row": "^2.14.0",
    "@tiptap/extension-task-item": "^2.14.0",
    "@tiptap/extension-task-list": "^2.14.0",
    "@tiptap/pm": "^2.14.0",
    "@tiptap/react": "^2.14.0",
    "@tiptap/starter-kit": "^2.14.0",
    "@tiptap/suggestion": "^2.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.6",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.511.0",
    "marked": "^15.0.12",
    "prosemirror-markdown": "^1.13.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  }
}
